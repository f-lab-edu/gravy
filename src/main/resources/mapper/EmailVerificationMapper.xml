<?xml version="1.0" encoding="UTF-8" ?>

<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="kr.gravy.gravy.email.mapper.EmailVerificationMapper">

    <resultMap id="EmailVerificationMap" type="kr.gravy.gravy.email.entity.EmailVerification">
        <id property="id" column="id" javaType="java.lang.Long"/>
        <result property="publicId" column="public_id" javaType="java.util.UUID"
                typeHandler="kr.gravy.gravy.infrastructure.persistence.mybatis.UUIDTypeHandler"/>
        <result property="verificationCode" column="verification_code" javaType="java.lang.String"/>
        <result property="status" column="status" javaType="kr.gravy.gravy.email.model.EmailVerificationStatus"/>
        <result property="email" column="email" javaType="java.lang.String"/>
        <result property="createdAt" column="created_at" javaType="java.time.LocalDateTime"/>
        <result property="updatedAt" column="updated_at" javaType="java.time.LocalDateTime"/>
    </resultMap>

    <select id="getLatestVerification" resultMap="EmailVerificationMap">
        SELECT *
        FROM email_verification
        WHERE email = #{email}
          AND status = 'SENT'
        ORDER BY created_at DESC LIMIT 1
    </select>

    <select id="getEmailAndVerificationStatusCode" resultMap="EmailVerificationMap">
        SELECT *
        FROM email_verification
        WHERE public_id = #{emailVerificationPublicId}
    </select>

    <update id="updateVerificationStatus">
        UPDATE email_verification
        SET status     = #{emailVerificationStatus},
            updated_at = now()
        WHERE id = #{emailVerificationId}
    </update>


    <insert id="insertVerificationCode">
        INSERT INTO email_verification(verification_code, public_id, status, email)
        VALUES (#{verificationCode}, #{publicId}, #{status}, #{email})
    </insert>

</mapper>
